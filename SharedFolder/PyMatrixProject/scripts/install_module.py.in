#!/usr/bin/env python3
"""
自动安装Python模块的脚本
"""
import os
import sys
import shutil
import platform

def install_pymatrix():
    """安装pymatrix模块"""
    
    # 获取平台信息
    system = platform.system()
    is_64bit = platform.machine().endswith('64')
    
    # 源文件路径
    build_dir = "@CMAKE_BINARY_DIR@"
    
    # 根据平台确定模块文件
    if system == "Windows":
        module_file = "pymatrix.cp*.pyd"
        module_pattern = os.path.join(build_dir, "lib", "**", "pymatrix*.pyd")
    elif system == "Darwin":
        module_file = "pymatrix*.so"
        module_pattern = os.path.join(build_dir, "lib", "**", "pymatrix*.so")
    else:  # Linux
        module_file = "pymatrix*.so"
        module_pattern = os.path.join(build_dir, "lib", "**", "pymatrix*.so")
    
    # 查找模块文件
    import glob
    module_files = glob.glob(module_pattern, recursive=True)
    
    if not module_files:
        print(f"错误: 找不到Python模块文件")
        print(f"搜索路径: {module_pattern}")
        return False
    
    source_file = module_files[0]
    print(f"找到模块文件: {source_file}")
    
    # 目标目录: 项目根目录下的 examples 文件夹
    project_root = "@CMAKE_SOURCE_DIR@"
    target_dir = os.path.join(project_root, "examples")
    
    if not os.path.exists(target_dir):
        os.makedirs(target_dir)
    
    print(f"目标安装目录: {target_dir}")
    
    # 复制文件
    target_file = os.path.join(target_dir, os.path.basename(source_file))
    try:
        shutil.copy2(source_file, target_file)
        print(f"成功安装到: {target_file}")
        return True
    except Exception as e:
        print(f"安装失败: {e}")
        return False

if __name__ == "__main__":
    success = install_pymatrix()
    sys.exit(0 if success else 1)